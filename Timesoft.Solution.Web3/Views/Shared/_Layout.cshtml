<!doctype html>
@{
    var currentAction = ViewContext.RouteData.Values["action"] == null
        ? string.Empty
        : ViewContext.RouteData.Values["action"].ToString();
    var isLeaveCalculationActive = string.Equals(currentAction, "Index", StringComparison.OrdinalIgnoreCase);
    var isViewLeaveActive = string.Equals(currentAction, "ViewLeave", StringComparison.OrdinalIgnoreCase);
}
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title - Timesoft.Solution.Web3 Framework MVC UI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="@Url.Content("~/Content/site.css")" rel="stylesheet" />
</head>
<body>
    <nav class="navbar navbar-expand-lg app-nav mb-4">
        <div class="container app-nav-inner">
            <a class="navbar-brand fw-semibold" href="@Url.Action("Index", "Home")">Leave Calculation Demo</a>
            <div class="navbar-nav app-menu">
                <a class="nav-link app-menu-link @(isLeaveCalculationActive ? "active" : "")" href="@Url.Action("Index", "Home")">Leave Calculation</a>
                <a class="nav-link app-menu-link @(isViewLeaveActive ? "active" : "")" href="@Url.Action("ViewLeave", "Home")">View Leave</a>
            </div>
            <span class="navbar-text app-framework-label">.NET 4.8</span>
        </div>
    </nav>

    <main class="container pb-5">
        @RenderBody()
    </main>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
