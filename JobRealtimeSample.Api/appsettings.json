{
  "Cors": {
    "AllowedOrigins": [
      "https://localhost:5001",
      "http://localhost:5001",
      "https://localhost:5101",
      "http://localhost:5101"
    ]
  },
  "RealtimeHub": {
    "NotificationEndpoint": "https://localhost:5003/api/notifications/job-status",
    "LeaveCalculationNotificationEndpoint": "https://localhost:5003/api/notifications/leave-calculation-status",
    "NotificationUsername": "sample-api",
    "NotificationPassword": "sample-secret"
  },
  "HubToken": {
    "Secret": "dev-only-demo-hub-token-secret",
    "LifetimeMinutes": 30
  },
  "LeaveCalculation": {
    "XmlPath": "App_Data/LeaveCalculationJobs.xml",
    "InitialDelaySeconds": 0,
    "StepDelaySeconds": 15
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
