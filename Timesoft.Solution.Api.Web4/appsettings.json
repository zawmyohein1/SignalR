{
  "Cors": {
    "AllowedOrigins": {
      "Web4": "xxxx"
    }
  },
  "SignalR": {
    "Enabled": true,
    "Provider": "Azure"
  },
  "ServiceBus": {
    "ConnectionString": "xxxx",
    "QueueName": "leave-calculation-status",
    "TransportType": "AmqpWebSockets"
  },
  "HubToken": {
    "Secret": "xxxx",
    "LifetimeMinutes": 30
  },
  "LeaveCalculation": {
    "XmlPath": "App_Data/LeaveCalculationJobs.xml",
    "InitialDelaySeconds": 0,
    "StepDelaySeconds": 5,
    "LeaveCodeDelaySeconds": 0.1
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
