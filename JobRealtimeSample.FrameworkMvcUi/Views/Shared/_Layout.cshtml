<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title - JobRealtimeSample Framework MVC UI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="@Url.Content("~/Content/site.css")" rel="stylesheet" />
</head>
<body>
    <nav class="navbar navbar-expand-lg app-nav mb-4">
        <div class="container">
            <a class="navbar-brand fw-semibold" href="@Url.Action("Index", "Home")">Leave Calculation Demo</a>
            <span class="navbar-text">ASP.NET MVC 5 on .NET Framework 4.8</span>
        </div>
    </nav>

    <main class="container pb-5">
        @RenderBody()
    </main>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
