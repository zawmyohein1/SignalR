<!DOCTYPE html>
@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var isLeaveCalculationActive = string.Equals(currentAction, "Index", StringComparison.OrdinalIgnoreCase);
    var isViewLeaveActive = string.Equals(currentAction, "ViewLeave", StringComparison.OrdinalIgnoreCase);
}
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Timesoft.Solution.Web4 .NET 8 MVC UI</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Timesoft.Solution.Web4.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light app-nav mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Leave Calculation</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav app-menu flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link app-menu-link @(isLeaveCalculationActive ? "active" : "")"
                               asp-area=""
                               asp-controller="Home"
                               asp-action="Index">Leave Calculation</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-menu-link @(isViewLeaveActive ? "active" : "")"
                               asp-area=""
                               asp-controller="Home"
                               asp-action="ViewLeave">View Leave</a>
                        </li>
                    </ul>
                    <span class="navbar-text app-framework-label">.NET 8</span>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Timesoft.Solution.Web4
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
