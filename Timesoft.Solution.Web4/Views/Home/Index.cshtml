@model Timesoft.Solution.Web4.Models.LeaveCalculationPageViewModel
@{
    ViewData["Title"] = "Leave Calculation";
    var signalRClientUrl = "https://cdn.jsdelivr.net/npm/@microsoft/signalr@8/dist/browser/signalr.min.js";
}

<section id="leaveCalculationApp"
         class="leave-calculation-app"
         data-calculation-proxy-url="@Url.Content("~/LeaveCalculations")"
         data-hub-url="@Model.HubUrl"
         data-signalr-enabled="@Model.SignalREnabled.ToString().ToLowerInvariant()"
         data-restore-storage="@Model.RestoreStorageMode"
         data-signalr-provider="@Model.SignalRProvider">

    @* Login screen *@
    <div id="loginPanel" class="login-stage">
        <div class="login-copy">
            <p class="eyebrow">TIMES SOFTWARE</p>
            <h1>Leave Calculation realtime experience</h1>
            <p>
                Select a company, sign in as an HR user, then start a leave entitlement process.
                The API returns a calculation id fast while progress arrives later through SignalR.
            </p>
        </div>

        <div class="login-box">
            <div class="brand-mark"><span>TIMES</span><strong>SOFTWARE</strong></div>

            <div class="mb-3">
                <label for="companyCode" class="form-label">Company</label>
                <select id="companyCode" class="form-select">
                    @foreach (var company in Model.Companies)
                    {
                        <option value="@company.Value">@company.Text</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label for="loginUserId" class="form-label">Login Id</label>
                <input id="loginUserId" class="form-control" value="HR_A" maxlength="30" />
            </div>

            <div class="mb-3">
                <label for="loginPassword" class="form-label">Password</label>
                <input id="loginPassword" class="form-control" type="password" value="password" maxlength="30" />
            </div>

            <div class="mb-4">
                <label class="form-label">Login Period</label>
                <div class="period-grid">
                    <select id="loginYear" class="form-select">
                        <option selected>@Model.CurrentYear</option>
                        <option>@(Model.CurrentYear + 1)</option>
                    </select>
                    <select id="loginMonth" class="form-select">
                        <option value="01">01</option>
                        <option value="02">02</option>
                        <option value="03">03</option>
                        <option value="04" selected>04</option>
                        <option value="05">05</option>
                        <option value="06">06</option>
                        <option value="07">07</option>
                        <option value="08">08</option>
                        <option value="09">09</option>
                        <option value="10">10</option>
                        <option value="11">11</option>
                        <option value="12">12</option>
                    </select>
                </div>
            </div>

            <button id="loginButton" type="button" class="btn btn-outline-primary login-button">Login</button>
            <p class="login-hint">Test-only access. No production authentication is used here.</p>
        </div>
    </div>

    @* Leave calculation screen *@
    <div id="calculationPanel" class="calculation-stage d-none">
        <div class="page-heading">
            <div>
                <p class="eyebrow">MANAGEMENT TOOLS</p>
                <h1>Leave Calculation</h1>
                <p>
                    Recalculate leave entitlements without holding one long HTTP request open.
                    Progress is isolated by company, user, and calculation id.
                </p>
            </div>
            <div class="context-box">
                <span id="contextCompany">Company</span>
                <strong id="contextUser">User</strong>
                <small id="contextPeriod">Period</small>
            </div>
        </div>

        <div class="work-grid">
            @* Process form *@
            <div class="process-panel">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label for="departmentCode" class="form-label">Department</label>
                        <select id="departmentCode" class="form-select">
                            @foreach (var department in Model.Departments)
                            {
                                <option value="@department.Value">@department.Text</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label for="employeeNo" class="form-label">Employee</label>
                        <select id="employeeNo" class="form-select">
                            @foreach (var employee in Model.Employees)
                            {
                                <option value="@employee.Value">@employee.Text</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label for="calculationYear" class="form-label">Year</label>
                        <select id="calculationYear" class="form-select">
                            <option selected>@Model.CurrentYear</option>
                            <option>@(Model.CurrentYear + 1)</option>
                        </select>
                    </div>

                    <div class="col-md-6 d-flex align-items-end">
                        <button id="processButton" type="button" class="btn btn-primary process-button">Process</button>
                    </div>
                </div>
            </div>

            @* Runtime status *@
            <div class="status-panel">
                <div class="status-row">
                    <span>SignalR Provider</span>
                    <strong id="signalrProviderDisplay" class="badge signalr-provider-badge text-bg-secondary">@Model.SignalRProvider</strong>
                </div>
                <div class="status-row">
                    <span>SignalR</span>
                    <strong id="signalrState" class="badge text-bg-secondary">Disconnected</strong>
                </div>
                <div class="status-row">
                    <span>Execution Mode</span>
                    <strong id="executionModeDisplay">Waiting for process</strong>
                </div>
                <div class="status-row">
                    <span>Calculation Id</span>
                    <strong id="calculationIdDisplay" class="text-break">No calculation started</strong>
                </div>
                <div class="status-row">
                    <span>Current Status</span>
                    <strong id="currentStatusDisplay" class="badge text-bg-secondary">Idle</strong>
                </div>
                <div class="status-row">
                    <span>API Response</span>
                    <strong id="apiResponseDisplay">Waiting for process</strong>
                </div>
            </div>
        </div>

        @* Progress log *@
        <div class="mt-4">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h2 class="h5 mb-0">Progress Log</h2>
                <span id="logModeHint" class="small text-muted">Only this browser group receives these updates.</span>
            </div>
            <div id="progressLog" class="job-log" aria-live="polite">
                <p class="text-muted mb-0">Click Process to start Leave Calculation.</p>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @if (Model.SignalREnabled)
    {
        <script src="@signalRClientUrl"></script>
    }
    <script src="~/js/leave-calculation-signalr-client.js" asp-append-version="true"></script>
    <script>
        $(function () {
            // Page wiring stays here.
            const $app = $("#leaveCalculationApp");

            if (!$app.length) {
                return;
            }

            const calculationProxyUrl = $app.data("calculationProxyUrl") || "/LeaveCalculations";
            const hubUrl = $app.data("hubUrl");
            const signalREnabled = $app.data("signalrEnabled") === true || $app.data("signalrEnabled") === "true";
            const restoreStorageMode = normalizeRestoreStorageMode($app.data("restoreStorage"));
            const activeCalculationStorageKey = "timesoft.leaveCalculation.active";
            const loginContextStorageKey = "timesoft.leaveCalculation.loginContext";
            const processingButtonHtml = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Processing...';
            const synchronousExecutionMode = "SynchronousHttp";
            const realtimeClient = window.leaveCalculationSignalRClient;

            const statusClasses = {
                Accepted: "text-bg-secondary",
                Started: "text-bg-primary",
                "Calculating leave entitlement": "text-bg-warning",
                Completed: "text-bg-success",
                Failed: "text-bg-danger"
            };

            const logStatusLabels = {
                "Calculating leave entitlement": "Calculating",
                "HTTP response": "HTTP response"
            };

            let loginContext = null;
            let currentCalculationId = null;

            realtimeClient.configure({
                calculationProxyUrl: calculationProxyUrl,
                hubUrl: hubUrl,
                signalRProvider: $app.data("signalrProvider") || "Local",
                signalREnabled: signalREnabled,
                callbacks: {
                    onSignalRState: setSignalRState,
                    onStatus: setStatus,
                    onLog: appendLog,
                    onFinish: finishProcess
                }
            });

            bindEvents();
            updateLoginUserFromCompany();
            restoreSavedCalculation().catch(function (error) {
                appendLog("Failed", getAjaxErrorMessage(error), new Date());
            });

            function bindEvents() {
                $("#companyCode").on("change", updateLoginUserFromCompany);
                $("#loginButton").on("click", handleLoginClick);
                $("#processButton").on("click", handleProcessClick);
            }

            function updateLoginUserFromCompany() {
                // Keep the login id aligned with the selected company.
                const companyCode = $("#companyCode").val();
                const suffix = companyCode === "COMPANY_A" ? "A" : companyCode === "COMPANY_B" ? "B" : "C";

                $("#loginUserId").val(`HR_${suffix}`);
            }

            function handleLoginClick() {
                const loginUserId = ($("#loginUserId").val() || "").trim();

                if (!loginUserId) {
                    alert("Login Id is required.");
                    return;
                }

                loginContext = {
                    companyCode: $("#companyCode").val(),
                    companyText: $("#companyCode option:selected").text(),
                    loginUserId: loginUserId,
                    period: `${$("#loginYear").val()}/${$("#loginMonth").val()}`
                };

                saveLoginContext();
                showCalculationPanel();
                appendLog("Ready", "Login context selected. The next Process click will start Leave Calculation.", new Date());
            }

            function showCalculationPanel() {
                $("#contextCompany").text(loginContext.companyText);
                $("#contextUser").text(loginContext.loginUserId);
                $("#contextPeriod").text(`Period ${loginContext.period}`);
                $("#loginPanel").addClass("d-none");
                $("#calculationPanel").removeClass("d-none");
            }

            async function handleProcessClick() {
                // Start the job from the page.
                if (!loginContext) {
                    alert("Please login first.");
                    return;
                }

                const $button = $("#processButton");
                const requestStartedAt = performance.now();

                $button.prop("disabled", true).html(processingButtonHtml);
                await resetProcessUi();

               const msg = signalREnabled
                            ? 'The browser will not wait for the full calculation to finish'
                            : 'The browser will wait for the full calculation to finish';

               appendLog("HTTP request", `Posting Leave Calculation request. ${msg}`, new Date());

                try {
                    const response = await startCalculation(buildStartPayload());
                    const elapsedMilliseconds = Math.round(performance.now() - requestStartedAt);

                    await handleStartResponse(response, elapsedMilliseconds);
                } catch (error) {
                    setStatus("Failed", "Could not start Leave Calculation.");
                    appendLog("Failed", getAjaxErrorMessage(error), new Date());
                    $button.prop("disabled", false).text("Process");
                }
            }

            function buildStartPayload() {
                return {
                    companyCode: loginContext.companyCode,
                    loginUserId: loginContext.loginUserId,
                    departmentCode: $("#departmentCode").val(),
                    employeeNo: $("#employeeNo").val(),
                    year: Number($("#calculationYear").val())
                };
            }

            function startCalculation(payload) {
                return $.ajax({
                    url: `${calculationProxyUrl}/Start`,
                    method: "POST",
                    contentType: "application/json",
                    data: JSON.stringify(payload)
                });
            }

            async function handleStartResponse(response, elapsedMilliseconds) {
                currentCalculationId = response.calculationId;
                saveActiveCalculation(response);

                const isSynchronousHttp = response.executionMode === synchronousExecutionMode || response.signalREnabled === false;

                showStartResponse(response, elapsedMilliseconds, isSynchronousHttp);

                if (isSynchronousHttp) {
                    await completeSynchronousHttpFlow(response, elapsedMilliseconds);
                    return;
                }

                await realtimeClient.start(response);
                await realtimeClient.refreshSnapshot(currentCalculationId);
            }

            function showStartResponse(response, elapsedMilliseconds, isSynchronousHttp) {
                $("#calculationIdDisplay").text(currentCalculationId);
                $("#apiResponseDisplay").text(
                    isSynchronousHttp
                        ? `${response.status} in ${elapsedMilliseconds} ms`
                        : `202 Accepted in ${elapsedMilliseconds} ms`);
                $("#executionModeDisplay").text(isSynchronousHttp ? "Normal HTTP request" : "Background + SignalR");

                setStatus(response.status, response.message);
                appendLog(
                    response.status,
                    isSynchronousHttp
                        ? `${response.message} Normal HTTP request waited until the calculation finished.`
                        : `${response.message} Calculation id returned immediately.`,
                    new Date());
            }

            async function completeSynchronousHttpFlow(response, elapsedMilliseconds) {
                $("#logModeHint").text("SignalR is disabled. Browser receives the final API response after the request completes.");
                setSignalRState("Off", "text-bg-dark");

                try {
                    await realtimeClient.refreshSnapshot(currentCalculationId);
                } catch (error) {
                    setStatus("Failed", "Could not load the completed calculation.");
                    appendLog("Failed", getAjaxErrorMessage(error), new Date());
                }

                appendLog(
                    "HTTP response",
                    `API returned ${response.status} after ${elapsedMilliseconds} ms. No realtime callback was used.`,
                    new Date());
                finishProcess();
            }

            async function resetProcessUi() {
                await realtimeClient.reset();
                currentCalculationId = null;
                clearSavedCalculation();

                $("#calculationIdDisplay").text("No calculation started");
                $("#apiResponseDisplay").text("Waiting for API response");
                $("#executionModeDisplay").text("Waiting for process");
                $("#logModeHint").text(
                    signalREnabled
                        ? "Only this browser group receives these updates."
                        : "SignalR is disabled. Browser waits for the API response.");
                $("#progressLog").empty();

                setSignalRState(signalREnabled ? "Disconnected" : "Disabled by page config", "text-bg-secondary");
                setStatus("Accepted", "Request has not been sent yet.");
            }

            async function restoreSavedCalculation() {
                const savedCalculation = readSavedCalculation();

                if (!savedCalculation) {
                    restoreSavedLoginContext();
                    return;
                }

                loginContext = {
                    companyCode: savedCalculation.companyCode,
                    companyText: savedCalculation.companyText || savedCalculation.companyCode,
                    loginUserId: savedCalculation.loginUserId,
                    period: savedCalculation.period || ""
                };
                currentCalculationId = savedCalculation.calculationId;

                restoreFormSelections(savedCalculation);
                showCalculationPanel();
                $("#progressLog").empty();
                $("#calculationIdDisplay").text(currentCalculationId);
                $("#apiResponseDisplay").text("Restored from browser storage");
                $("#executionModeDisplay").text(
                    savedCalculation.executionMode === synchronousExecutionMode || savedCalculation.signalREnabled === false
                        ? "Normal HTTP request"
                        : "Background + SignalR");
                $("#logModeHint").text("Latest status is loaded from the saved calculation id.");
                $("#processButton").prop("disabled", true).html(processingButtonHtml);
                appendLog("Restored", `Restored calculation ${currentCalculationId}. Loading latest status.`, new Date());

                const snapshot = await realtimeClient.refreshSnapshot(currentCalculationId);

                if (isFinishedStatus(snapshot.status)) {
                    finishProcess();
                    return;
                }

                await realtimeClient.resume(savedCalculation);
                await realtimeClient.refreshSnapshot(currentCalculationId);
            }

            function restoreSavedLoginContext() {
                const savedLoginContext = readSavedLoginContext();

                if (!savedLoginContext) {
                    return;
                }

                loginContext = {
                    companyCode: savedLoginContext.companyCode,
                    companyText: savedLoginContext.companyText || savedLoginContext.companyCode,
                    loginUserId: savedLoginContext.loginUserId,
                    period: savedLoginContext.period || ""
                };

                restoreFormSelections(savedLoginContext);
                showCalculationPanel();
                $("#progressLog").empty();
                appendLog("Ready", "Login context restored. The next Process click will start Leave Calculation.", new Date());
            }

            function saveLoginContext() {
                const storage = getConfiguredStorage();

                if (!storage || !loginContext) {
                    return;
                }

                const savedLoginContext = {
                    companyCode: loginContext.companyCode,
                    companyText: loginContext.companyText,
                    loginUserId: loginContext.loginUserId,
                    period: loginContext.period,
                    savedAt: new Date().toISOString()
                };

                try {
                    storage.setItem(loginContextStorageKey, JSON.stringify(savedLoginContext));
                } catch (error) {
                    appendLog("Failed", "Browser storage is not available for login context.", new Date());
                }
            }

            function readSavedLoginContext() {
                const storage = getConfiguredStorage();

                if (!storage) {
                    return null;
                }

                try {
                    const rawValue = storage.getItem(loginContextStorageKey);

                    if (!rawValue) {
                        return null;
                    }

                    const savedLoginContext = JSON.parse(rawValue);
                    return savedLoginContext && savedLoginContext.companyCode && savedLoginContext.loginUserId
                        ? savedLoginContext
                        : null;
                } catch (error) {
                    storage.removeItem(loginContextStorageKey);
                    return null;
                }
            }

            function saveActiveCalculation(response) {
                const storage = getConfiguredStorage();

                if (!storage) {
                    return;
                }

                const activeCalculation = {
                    calculationId: response.calculationId,
                    companyCode: response.companyCode,
                    companyText: loginContext.companyText,
                    loginUserId: response.loginUserId,
                    period: loginContext.period,
                    departmentCode: $("#departmentCode").val(),
                    employeeNo: $("#employeeNo").val(),
                    year: Number($("#calculationYear").val()),
                    hubAccessToken: response.hubAccessToken,
                    executionMode: response.executionMode,
                    signalREnabled: response.signalREnabled,
                    startedAt: new Date().toISOString()
                };

                try {
                    storage.setItem(activeCalculationStorageKey, JSON.stringify(activeCalculation));
                } catch (error) {
                    appendLog("Failed", "Browser storage is not available for restore state.", new Date());
                }
            }

            function readSavedCalculation() {
                const storage = getConfiguredStorage();

                if (!storage) {
                    return null;
                }

                try {
                    const rawValue = storage.getItem(activeCalculationStorageKey);

                    if (!rawValue) {
                        return null;
                    }

                    const savedCalculation = JSON.parse(rawValue);
                    return savedCalculation && savedCalculation.calculationId
                        ? savedCalculation
                        : null;
                } catch (error) {
                    storage.removeItem(activeCalculationStorageKey);
                    return null;
                }
            }

            function clearSavedCalculation() {
                const storage = getConfiguredStorage();

                if (!storage) {
                    return;
                }

                storage.removeItem(activeCalculationStorageKey);
            }

            function restoreFormSelections(savedCalculation) {
                $("#companyCode").val(savedCalculation.companyCode);
                $("#loginUserId").val(savedCalculation.loginUserId);

                if (savedCalculation.departmentCode) {
                    $("#departmentCode").val(savedCalculation.departmentCode);
                }

                if (savedCalculation.employeeNo) {
                    $("#employeeNo").val(savedCalculation.employeeNo);
                }

                if (savedCalculation.year) {
                    $("#calculationYear").val(savedCalculation.year);
                }

                if (savedCalculation.period && savedCalculation.period.indexOf("/") > -1) {
                    const parts = savedCalculation.period.split("/");
                    $("#loginYear").val(parts[0]);
                    $("#loginMonth").val(parts[1]);
                }

                const selectedCompanyText = $("#companyCode option:selected").text();

                if (selectedCompanyText) {
                    loginContext.companyText = selectedCompanyText;
                }
            }

            function getConfiguredStorage() {
                if (restoreStorageMode === "off") {
                    return null;
                }

                try {
                    return restoreStorageMode === "local"
                        ? window.localStorage
                        : window.sessionStorage;
                } catch (error) {
                    return null;
                }
            }

            function normalizeRestoreStorageMode(value) {
                const mode = (value || "session").toString().toLowerCase();

                if (mode === "off" || mode === "local") {
                    return mode;
                }

                return "session";
            }

            function isFinishedStatus(status) {
                return status === "Completed" || status === "Failed";
            }

            function finishProcess() {
                $("#processButton").prop("disabled", false).text("Process");
            }

            function setStatus(status, message) {
                const badgeClass = statusClasses[status] || "text-bg-secondary";
                setBadge($("#currentStatusDisplay"), status, badgeClass);

                if (message) {
                    $("#currentStatusDisplay").attr("title", message);
                }
            }

            function setSignalRState(text, badgeClass) {
                setBadge($("#signalrState"), text, badgeClass);
            }

            function setBadge($element, text, badgeClass) {
                $element
                    .removeClass()
                    .addClass(`badge ${badgeClass}`)
                    .text(text);
            }

            function appendLog(status, message, timestamp) {
                const timeText = timestamp.toLocaleTimeString();
                const badgeClass = statusClasses[status] || "text-bg-dark";
                const displayStatus = logStatusLabels[status] || status;
                const entry = $(`
                    <div class="job-log-entry">
                        <div class="log-meta">
                            <span class="badge ${badgeClass}">${escapeHtml(displayStatus)}</span>
                            <time>${escapeHtml(timeText)}</time>
                        </div>
                        <p>${escapeHtml(message)}</p>
                    </div>
                `);

                $("#progressLog").append(entry);

                const log = $("#progressLog")[0];
                log.scrollTop = log.scrollHeight;
            }

            function getAjaxErrorMessage(error) {
                if (error && error.responseJSON && error.responseJSON.message) {
                    return error.responseJSON.message;
                }

                if (error && error.responseText) {
                    return error.responseText;
                }

                if (error && error.statusText) {
                    return `Request failed: ${error.statusText}`;
                }

                return "Request failed. Make sure the API and RealtimeHub projects are running.";
            }

            function escapeHtml(value) {
                return $("<div>").text(value || "").html();
            }
        });
    </script>
}
